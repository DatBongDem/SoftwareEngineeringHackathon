{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "MongoDbSettings": {
    "ConnectionString": "mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER_URL>/<DATABASE_NAME>?retryWrites=true&w=majority",
    "DatabaseName": "SEALHackathonDb"
  },
  "JwtSettings": {
    "Secret": "<YOUR_SUPER_SECRET_JWT_KEY_MIN_32_CHARS>",
    "Issuer": "SEALHackathonAPI",
    "Audience": "SEALHackathonClient",
    "ExpiryMinutes": 1440
  },
  "GoogleAuth": {
    "ClientId": "<YOUR_GOOGLE_CLIENT_ID>.apps.googleusercontent.com"
  }
}
